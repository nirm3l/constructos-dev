{
  "name": "constructos-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ConstructOS desktop shell for macOS, Windows, and Linux.",
  "homepage": "https://github.com/nirm3l/m4tr1x",
  "main": "main.cjs",
  "author": {
    "name": "ConstructOS",
    "email": "support@constructos.dev"
  },
  "license": "UNLICENSED",
  "scripts": {
    "start": "node scripts/run-electron.cjs",
    "start:no-sandbox": "electron --no-sandbox .",
    "package": "electron-builder --dir",
    "dist:ci": "node scripts/ci-dist.cjs",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.constructos.desktop",
    "productName": "ConstructOS",
    "asar": true,
    "afterSign": "scripts/notarize.cjs",
    "files": [
      "main.cjs",
      "preload.cjs",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "maintainer": "ConstructOS <support@constructos.dev>",
      "category": "Office"
    }
  }
}
